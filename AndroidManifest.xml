<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.TataConnect">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".AccountTypeActivity"
            android:exported="false" />
        <activity
            android:name=".SignUpFamilyActivity"
            android:exported="false" />
        <activity
            android:name=".SignUpEmployeeActivity"
            android:exported="false" />
        <activity
            android:name=".CompleteProfileFamilyActivity"
            android:exported="false" />
        <activity
            android:name=".CompleteProfileEmployeeActivity"
            android:exported="false" />
        <activity
            android:name=".HomeFamilyActivity"
            android:exported="false" />
        <activity
            android:name=".HomeEmployeeActivity"
            android:exported="false" />
        <activity
            android:name=".FamilyProfileActivity"
            android:exported="false" />
        <activity
            android:name=".InboxActivity"
            android:exported="false" />
        <activity
            android:name=".LoginActivity"
            android:exported="false" />
        <activity
            android:name=".BrowseHousekeepersActivity"
            android:exported="false" />
        <activity
            android:name=".HousekeeperProfileActivity"
            android:exported="false" />
        <activity
            android:name=".ChatActivity"
            android:exported="false" />
    </application>

</manifest>